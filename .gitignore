# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.so

# --- 虛擬環境 / uv ---
.venv/
venv/
env/
.python-version
# 注意：uv.lock 應該提交（保證可重現），不要忽略

# --- 測試 / 型別 / 覆蓋率 ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- 產生的輸出（舊版 flat 圖檔，已棄用，保留資料夾） ---
figures/*
!figures/.gitkeep

# --- 版本化結果 results/<版本>/ ---
# 規則：data/CSV、summary.json、manifest.json 進版控（輕量、可 diff、可重現）；
#       figures/PNG 忽略（可由腳本重生）。
results/**/figures/
results/*/figures/

# --- 私人筆記（只給自己看，不上傳） ---
_private_notes/

# --- 編輯器 / 作業系統 ---
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
.fuse_hidden*
